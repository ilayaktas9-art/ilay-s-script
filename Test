<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Diagnostics</title>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }
        body {
            font-family: 'Courier New', Courier, monospace;
            background-color: #0d0d0d;
            color: #00ff00;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            cursor: pointer;
            overflow: hidden;
            user-select: none;
        }

        .container {
            text-align: center;
            padding: 20px;
            z-index: 2;
        }

        h1 {
            font-size: 2rem;
            letter-spacing: 2px;
            margin-bottom: 20px;
            text-transform: uppercase;
        }

        .btn {
            background-color: #222;
            color: #00ff00;
            border: 2px solid #00ff00;
            padding: 15px 40px;
            font-size: 1.2rem;
            font-family: inherit;
            cursor: pointer;
            border-radius: 5px;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.4);
            transition: all 0.3s ease;
        }

        .btn:hover {
            background-color: #00ff00;
            color: #000;
            box-shadow: 0 0 25px rgba(0, 255, 0, 0.8);
        }

        #scareOverlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: #000000;
            z-index: 9999;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        #clownVideo {
            width: 100%;
            max-width: 600px;
            height: auto;
            border: 3px solid #ff0000;
            box-shadow: 0 0 30px rgba(255, 0, 0, 0.6);
            margin-bottom: 20px;
        }

        .ip-text {
            color: #ff0000;
            font-size: 3.5rem;
            font-weight: bold;
            font-family: 'Impact', sans-serif;
            letter-spacing: 3px;
            animation: glitch 0.2s infinite, pulse 1s infinite;
            text-shadow: 0 0 20px rgba(255, 0, 0, 0.8);
        }

        @keyframes glitch {
            0% { transform: translate(2px, 1px) rotate(0deg); }
            10% { transform: translate(-1px, -2px) rotate(-1deg); }
            20% { transform: translate(-3px, 0px) rotate(1deg); }
            30% { transform: translate(0px, 2px) rotate(0deg); }
            40% { transform: translate(1px, -1px) rotate(1deg); }
            50% { transform: translate(-1px, 2px) rotate(-1deg); }
            60% { transform: translate(-3px, 1px) rotate(0deg); }
            70% { transform: translate(2px, 1px) rotate(-1deg); }
            80% { transform: translate(-1px, -1px) rotate(1deg); }
            90% { transform: translate(2px, 2px) rotate(0deg); }
            100% { transform: translate(1px, -2px) rotate(-1deg); }
        }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
    </style>
</head>
<body>

    <div class="container" id="mainContent">
        <h1>System-Status: Aktiv</h1>
        <p>Klicke auf den Button, um die Verbindung zu prüfen...</p>
        <button class="btn" onclick="triggerScare()">Verbindung prüfen</button>
    </div>

    <div id="scareOverlay">
        <video id="clownVideo" playsinline>
            <source src="1000024723.mp4" type="video/mp4">
            Dein Browser unterstützt dieses Video nicht.
        </video>
        <div class="ip-text">YOUR IP 111.48.115.128 HAHAHA</div>
    </div>

    <script>
        function triggerScare() {
            var overlay = document.getElementById("scareOverlay");
            var mainContent = document.getElementById("mainContent");
            var video = document.getElementById("clownVideo");

            overlay.style.display = "flex";
            mainContent.style.display = "none";

            video.play().catch(function(error) {
                console.log("Wurde blockiert:", error);
            });

            video.loop = true;
        }
    </script>

</body>
</html
